{
    "model_name": "XGBoost Vessel Activity Classifier",
    "features": [
        "p95_speed",
        "p5_speed",
        "med_speed",
        "curviness",
        "heading_mean",
        "heading_std",
        "turning_mean",
        "turning_std",
        "distance_total",
        "distance_o"
    ],
    "params": {
        "learning_rate": 0.1,
        "max_depth": 13,
        "n_estimators": 350
    },
    "cv_accuracy": 0.9098943045031516,
    "test_accuracy": 0.9299610894941635,
    "label_mapping": {
        "0": "fishing",
        "1": "drifting",
        "2": "transit",
        "3": "hook",
        "4": "seine",
        "5": "stopped",
        "6": "lobster",
        "7": "trawl"
    },
    "notes": "Trained on summary statistics of vessel tracks. Stratified 80:20 split. 4-fold CV."
}